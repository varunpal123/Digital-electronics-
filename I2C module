// I2C Master Module for ATmega328P
// Implements Two-Wire Interface (TWI)

module i2c_master (
    input wire clk,
    input wire reset_n,
    
    // Configuration
    input wire [7:0] clock_div,    // SCL frequency divider
    
    // Control interface
    input wire start,             // Generate START condition
    input wire stop,              // Generate STOP condition
    input wire write,             // Write byte
    input wire read,              // Read byte
    input wire ack_bit,           // ACK to send when reading
    
    // Data interface
    input wire [7:0] tx_data,
    output reg [7:0] rx_data,
    
    // Status
    output reg busy,
    output reg done,
    output reg ack_received,      // ACK from slave
    output reg arbitration_lost,  // Bus arbitration lost
    
    // I2C pins (open-drain)
    inout wire sda,
    inout wire scl
);

    // Open-drain outputs
    reg sda_out, scl_out;
    wire sda_in, scl_in;
    
    assign sda = sda_out ? 1'bz : 1'b0;
    assign scl = scl_out ? 1'bz : 1'b0;
    assign sda_in = sda;
    assign scl_in = scl;
    
    // State machine
    localparam IDLE       = 4'b0000;
    localparam START      = 4'b0001;
    localparam WRITE_BYTE = 4'b0010;
    localparam READ_BYTE  = 4'b0011;
    localparam WRITE_ACK  = 4'b0100;
    localparam READ_ACK   = 4'b0101;
    localparam STOP       = 4'b0110;
    
    reg [3:0] state;
    reg [2:0] bit_counter;
    reg [7:0] shift_reg;
    reg [7:0] clk_counter;
    reg scl_tick;
    
    // Clock generation
    always @(posedge clk or negedge reset_n) begin
        if (!reset_n) begin
            clk_counter <= 0;
            scl_tick <= 0;
        end else if (state != IDLE) begin
            if (clk_counter >= clock_div - 1) begin
                clk_counter <= 0;
                scl_tick <= 1;
            end else begin
                clk_counter <= clk_counter + 1;
                scl_tick <= 0;
            end
        end else begin
            clk_counter <= 0;
            scl_tick <= 0;
        end
    end
    
    // I2C state machine
    reg [1:0] phase;  // 4 phases per bit
    
    always @(posedge clk or negedge reset_n) begin
        if (!reset_n) begin
            state <= IDLE;
            sda_out <= 1;
            scl_out <= 1;
            busy <= 0;
            done <= 0;
            ack_received <= 0;
            arbitration_lost <= 0;
            bit_counter <= 0;
            phase <= 0;
        end else begin
            done <= 0;
            
            case (state)
                IDLE: begin
                    busy <= 0;
                    sda_out <= 1;
                    scl_out <= 1;
                    arbitration_lost <= 0;
                    
                    if (start) begin
                        busy <= 1;
                        state <= START;
                        phase <= 0;
                    end else if (write) begin
                        shift_reg <= tx_data;
                        bit_counter <= 0;
                        busy <= 1;
                        state <= WRITE_BYTE;
                        phase <= 0;
                    end else if (read) begin
                        bit_counter <= 0;
                        busy <= 1;
                        state <= READ_BYTE;
                        phase <= 0;
                    end else if (stop) begin
                        busy <= 1;
                        state <= STOP;
                        phase <= 0;
                    end
                end
                
                START: begin
                    if (scl_tick) begin
                        case (phase)
                            0: begin sda_out <= 1; scl_out <= 1; end  // Both high
                            1: begin sda_out <= 0; scl_out <= 1; end  // SDA falls
                            2: begin sda_out <= 0; scl_out <= 0; end  // SCL falls
                            3: begin
                                state <= IDLE;
                                done <= 1;
                            end
                        endcase
                        phase <= phase + 1;
                    end
                end
                
                WRITE_BYTE: begin
                    if (scl_tick) begin
                        case (phase)
                            0: begin
                                // Setup data
                                sda_out <= shift_reg[7];
                                scl_out <= 0;
                            end
                            1: begin
                                // Clock high
                                scl_out <= 1;
                            end
                            2: begin
                                // Check for arbitration
                                if (sda_out && !sda_in) begin
                                    arbitration_lost <= 1;
                                    state <= IDLE;
                                end
                            end
                            3: begin
                                // Clock low, shift data
                                scl_out <= 0;
                                shift_reg <= {shift_reg[6:0], 1'b0};
                                bit_counter <= bit_counter + 1;
                                
                                if (bit_counter == 7) begin
                                    state <= READ_ACK;
                                end
                            end
                        endcase
                        phase <= phase + 1;
                    end
                end
                
                READ_BYTE: begin
                    if (scl_tick) begin
                        case (phase)
                            0: begin
                                sda_out <= 1;  // Release SDA
                                scl_out <= 0;
                            end
                            1: begin
                                scl_out <= 1;  // Clock high
                            end
                            2: begin
                                // Sample data
                                shift_reg <= {shift_reg[6:0], sda_in};
                            end
                            3: begin
                                scl_out <= 0;
                                bit_counter <= bit_counter + 1;
                                
                                if (bit_counter == 7) begin
                                    rx_data <= {shift_reg[6:0], sda_in};
                                    state <= WRITE_ACK;
                                end
                            end
                        endcase
                        phase <= phase + 1;
                    end
                end
                
                READ_ACK: begin
                    if (scl_tick) begin
                        case (phase)
                            0: begin
                                sda_out <= 1;  // Release SDA
                                scl_out <= 0;
                            end
                            1: scl_out <= 1;
                            2: ack_received <= ~sda_in;  // ACK is low
                            3: begin
                                scl_out <= 0;
                                state <= IDLE;
                                done <= 1;
                            end
                        endcase
                        phase <= phase + 1;
                    end
                end
                
                WRITE_ACK: begin
                    if (scl_tick) begin
                        case (phase)
                            0: begin
                                sda_out <= ~ack_bit;  // ACK=0, NACK=1
                                scl_out <= 0;
                            end
                            1: scl_out <= 1;
                            2: ;  // Hold
                            3: begin
                                scl_out <= 0;
                                state <= IDLE;
                                done <= 1;
                            end
                        endcase
                        phase <= phase + 1;
                    end
                end
                
                STOP: begin
                    if (scl_tick) begin
                        case (phase)
                            0: begin sda_out <= 0; scl_out <= 0; end
                            1: begin sda_out <= 0; scl_out <= 1; end  // SCL rises
                            2: begin sda_out <= 1; scl_out <= 1; end  // SDA rises
                            3: begin
                                state <= IDLE;
                                done <= 1;
                            end
                        endcase
                        phase <= phase + 1;
                    end
                end
                
                default: state <= IDLE;
            endcase
        end
    end

endmodule
